{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Codex",
      "type": "debugpy",
      "request": "launch",
      "module": "src.main",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python3",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "G_MESSAGES_DEBUG": "all"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python3",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
